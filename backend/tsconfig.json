{
  "compilerOptions": {
    "target": "ES2020", // modern JS features
    "module": "commonjs", // Node module system
    "moduleResolution": "node",
    "strict": true, // strict type checking
    "esModuleInterop": true, // allows import default from commonjs
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"] // <-- this makes Buffer and other Node globals available
  },
  "include": ["src/**/*"]
}
